{
  "name": "flawless-voice-agent",
  "version": "0.1.0",
  "description": "Optimal hybrid voice agent — dual-path architecture (fast/deep/fallback), registry-driven, compliance-ready",
  "type": "module",
  "main": "dist/src/index.js",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "start": "node dist/src/index.js",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "notifications:triage": "tsx scripts/notifications-triage.ts",
    "notifications:triage:apply": "tsx scripts/notifications-triage.ts --scope global --apply",
    "clean": "rm -rf dist",
    "compliance:check": "echo \"compliance check placeholder\"",
    "eval:smoke": "echo \"eval smoke placeholder\"",
    "eval:regression": "echo \"eval regression placeholder\""
  },
  "dependencies": {
    "@fastify/formbody": "^7.4.0",
    "@fastify/websocket": "^8.3.1",
    "dotenv": "^16.4.5",
    "fastify": "^5.8.5",
    "openai": "^4.0.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.12.7",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^7.8.0",
    "@typescript-eslint/parser": "^7.8.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "pino-pretty": "13.1.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.2",
    "tsx": "^4.7.3",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
