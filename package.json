{
  "name": "flawless-voice-agent",
  "version": "0.1.0",
  "description": "Optimal hybrid voice agent platform — dual-path, registry-driven, compliance-ready, scalable to 10k concurrent calls",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "test:e2e": "jest tests/e2e",
    "test:load": "node tests/load/runner.js",
    "eval": "ts-node eval/run-evals.ts",
    "eval:smoke": "ts-node eval/run-evals.ts --mode=smoke",
    "eval:regression": "ts-node eval/run-evals.ts --mode=regression",
    "eval:golden": "ts-node eval/run-evals.ts --mode=golden",
    "registry:validate": "ts-node scripts/validate-registry.ts",
    "registry:audit": "ts-node scripts/audit-registry.ts",
    "compliance:check": "ts-node scripts/compliance-check.ts",
    "schema:validate": "ts-node scripts/validate-schemas.ts",
    "docker:up": "docker-compose up --build",
    "docker:down": "docker-compose down",
    "prepare": "npm run build"
  },
  "dependencies": {
    "twilio": "^5.0.0",
    "openai": "^4.0.0",
    "express": "^4.18.0",
    "ws": "^8.0.0",
    "redis": "^4.6.0",
    "dotenv": "^16.0.0",
    "zod": "^3.22.0",
    "pino": "^8.0.0",
    "pino-pretty": "^10.0.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "ts-node": "^10.9.0",
    "@types/node": "^20.0.0",
    "@types/express": "^4.17.0",
    "@types/ws": "^8.5.0",
    "eslint": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "prettier": "^3.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "@types/jest": "^29.0.0",
    "supertest": "^6.3.0",
    "@types/supertest": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT",
  "author": "Flawless Studio <oneflawlessstudio@gmail.com>"
}
