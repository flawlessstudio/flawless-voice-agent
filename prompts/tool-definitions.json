[
  {
    "type": "function",
    "name": "log_to_crm",
    "description": "Logs the call outcome, summary, and intent to the CRM. Must be called at the end of every conversation.",
    "parameters": {
      "type": "object",
      "properties": {
        "intent": {
          "type": "string",
          "enum": ["qualify", "schedule", "support", "objection", "handoff", "other"],
          "description": "Primary intent detected during the call"
        },
        "summary": {
          "type": "string",
          "description": "2-3 sentence summary of the call outcome"
        },
        "outcome": {
          "type": "string",
          "enum": ["success", "callback", "not_interested", "transferred", "voicemail", "no_answer"],
          "description": "Final outcome of the call"
        },
        "contact_id": {
          "type": "string",
          "description": "CRM contact ID if known"
        }
      },
      "required": ["intent", "summary", "outcome"]
    }
  },
  {
    "type": "function",
    "name": "check_availability",
    "description": "Checks calendar availability for a given date range before suggesting meeting slots.",
    "parameters": {
      "type": "object",
      "properties": {
        "date_from": {
          "type": "string",
          "description": "Start of range ISO8601 (YYYY-MM-DD)"
        },
        "date_to": {
          "type": "string",
          "description": "End of range ISO8601 (YYYY-MM-DD)"
        }
      },
      "required": ["date_from", "date_to"]
    }
  },
  {
    "type": "function",
    "name": "transfer_call",
    "description": "Transfers the active call to a human agent. Use when caller requests human, situation is too complex, or caller is distressed.",
    "parameters": {
      "type": "object",
      "properties": {
        "reason": {
          "type": "string",
          "description": "Reason for transfer"
        },
        "summary": {
          "type": "string",
          "description": "Brief summary of call so far for the receiving agent"
        }
      },
      "required": ["reason", "summary"]
    }
  }
]
