{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "version": "1.0.0",
  "updated": "2026-05-30",
  "tools": [
    {
      "name": "check_dnc_status",
      "description": "Verify if a phone number is on a Do-Not-Call registry before initiating or continuing an outbound call. Must be called before any outbound interaction.",
      "parameters": {
        "type": "object",
        "properties": {
          "phone_number": {
            "type": "string",
            "description": "E.164 formatted phone number (e.g. +34612345678)"
          },
          "country_code": {
            "type": "string",
            "description": "ISO 3166-1 alpha-2 country code (e.g. ES, US, GB)"
          }
        },
        "required": ["phone_number", "country_code"]
      }
    },
    {
      "name": "verify_consent",
      "description": "Verify that explicit consent has been captured and stored for the given contact before processing their data or continuing the call.",
      "parameters": {
        "type": "object",
        "properties": {
          "contact_id": {
            "type": "string",
            "description": "Unique identifier for the contact"
          },
          "consent_type": {
            "type": "string",
            "enum": ["marketing", "service", "data_processing"],
            "description": "Type of consent to verify"
          }
        },
        "required": ["contact_id", "consent_type"]
      }
    },
    {
      "name": "escalate_to_human",
      "description": "Transfer the current call to a human agent. Use when: user requests human, compliance block triggered, agent confidence < threshold, or 3+ failed intent attempts.",
      "parameters": {
        "type": "object",
        "properties": {
          "reason": {
            "type": "string",
            "enum": ["user_request", "compliance_block", "low_confidence", "max_retries", "technical_error"],
            "description": "Reason for escalation"
          },
          "session_id": {
            "type": "string",
            "description": "Current session ID for handoff context"
          },
          "summary": {
            "type": "string",
            "description": "Brief summary of the conversation so far for the human agent"
          }
        },
        "required": ["reason", "session_id"]
      }
    },
    {
      "name": "log_audit_event",
      "description": "Record an auditable decision or action taken by the agent. Required for compliance trail on all calls.",
      "parameters": {
        "type": "object",
        "properties": {
          "session_id": {
            "type": "string",
            "description": "Session identifier"
          },
          "event_type": {
            "type": "string",
            "enum": ["call_started", "consent_verified", "dnc_checked", "ai_disclosure_given", "intent_classified", "escalated", "call_ended"],
            "description": "Type of auditable event"
          },
          "metadata": {
            "type": "object",
            "description": "Additional event context (no PII)"
          }
        },
        "required": ["session_id", "event_type"]
      }
    },
    {
      "name": "get_call_script",
      "description": "Retrieve the approved call script or talk track for a given campaign and intent.",
      "parameters": {
        "type": "object",
        "properties": {
          "campaign_id": {
            "type": "string",
            "description": "Campaign identifier"
          },
          "intent": {
            "type": "string",
            "description": "Detected user intent (e.g. schedule_appointment, pricing_inquiry)"
          },
          "language": {
            "type": "string",
            "description": "BCP-47 language tag (e.g. en-US, es-ES)"
          }
        },
        "required": ["campaign_id", "intent"]
      }
    }
  ]
}
