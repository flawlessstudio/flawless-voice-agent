# ============================================================
# Flawless Voice Agent — Environment Variables
# ============================================================
# Copy this file to .env and fill in all required values.
# Never commit .env to version control.
# Run: bash scripts/health-check.sh to verify connectivity.

# ---- Server -------------------------------------------------
PORT=5050
NODE_ENV=development
PUBLIC_URL=https://your-ngrok-or-domain.com

# ---- Twilio -------------------------------------------------
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+34600000000
TWILIO_TRANSFER_TWIML_URL=https://your-domain.com/transfer-twiml

# ---- OpenAI -------------------------------------------------
OPENAI_API_KEY=sk-...
# Model for post-call analysis (cheaper than realtime, gpt-4o-mini recommended)
ANALYSIS_MODEL=gpt-4o-mini

# ---- Deepgram -----------------------------------------------
DEEPGRAM_API_KEY=your_deepgram_key

# ---- ElevenLabs ---------------------------------------------
ELEVENLABS_API_KEY=your_elevenlabs_key
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL_ID=eleven_turbo_v2

# ---- Vapi ---------------------------------------------------
VAPI_API_KEY=your_vapi_key
VAPI_PHONE_NUMBER_ID=your_vapi_phone_number_id
VAPI_ASSISTANT_ID=your_vapi_assistant_id

# ---- Retell -------------------------------------------------
RETELL_API_KEY=your_retell_key
RETELL_AGENT_ID=your_retell_agent_id

# ---- HubSpot ------------------------------------------------
HUBSPOT_ACCESS_TOKEN=your_hubspot_private_app_token
# Optional: HubSpot Calling Extension App ID
HUBSPOT_APP_ID=your_hubspot_app_id

# ---- Salesforce ---------------------------------------------
SALESFORCE_INSTANCE_URL=https://your-org.my.salesforce.com
SALESFORCE_ACCESS_TOKEN=your_salesforce_access_token
SALESFORCE_CALL_CENTER_NAME=FlawlessVoiceAgent

# ---- Observability (Langfuse) --------------------------------
# Optional: leave empty to use console fallback
# Self-hosted: run `docker-compose -f infra/langfuse.yml up -d`
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# ---- Agent --------------------------------------------------
AGENT_NAME=Alex
# Orchestrator: direct | vapi | retell
ORCHESTRATOR=direct

# ---- Multi-agent handoff ------------------------------------
HUMAN_AGENT_NUMBER=+34900000000
SDR_AGENT_ID=sdr_default
SUPPORT_AGENT_ID=support_default

# ---- Redis (optional, for multi-instance deployments) --------
# REDIS_URL=redis://localhost:6379
