ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL_ID=eleven_turbo_v2
ELEVENLABS_AGENT_ID=

# --- Vapi ---
# dashboard.vapi.ai > API Keys
# VAPI_PHONE_NUMBER_ID: ID of imported Twilio number in Vapi
