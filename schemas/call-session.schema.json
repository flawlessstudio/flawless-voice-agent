{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "call-session.schema.json",
  "title": "CallSession",
  "type": "object",
  "required": ["sessionId", "callSid", "startedAt", "path", "status"],
  "properties": {
    "sessionId": { "type": "string" },
    "callSid": { "type": "string" },
    "startedAt": { "type": "string", "format": "date-time" },
    "endedAt": { "type": "string", "format": "date-time" },
    "path": { "type": "string", "enum": ["fast", "deep", "fallback"] },
    "status": { "type": "string", "enum": ["active", "completed", "failed", "handed-off"] },
    "handoffAt": { "type": "string", "format": "date-time" },
    "crmSynced": { "type": "boolean" },
    "consentCaptured": { "type": "boolean" },
    "latencyP95Ms": { "type": "number" },
    "turns": { "type": "number" }
  }
}
