{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "audit-entry.schema.json",
  "title": "AuditEntry",
  "type": "object",
  "required": ["date", "action", "layer", "candidate", "reason", "author"],
  "properties": {
    "date": { "type": "string", "format": "date" },
    "action": {
      "type": "string",
      "enum": ["ADD_CORE", "REMOVE_CORE", "ADD_WATCHLIST", "REMOVE_WATCHLIST", "PROMOTE", "DEMOTE", "DEPRECATE"]
    },
    "layer": { "type": "string" },
    "candidate": { "type": "string" },
    "reason": { "type": "string" },
    "author": { "type": "string" }
  }
}
